# 이 파일을 복사해 .env 로 저장한 뒤 실제 값을 입력하세요.
#   copy .env.sample .env   (Windows)
#   cp .env.sample .env     (macOS/Linux)
#
# .env 는 Git·Cursor 모두에서 제외됩니다.

# ── Supabase ──────────────────────────────────────────
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── 검색 API ──────────────────────────────────────────
TAVILY_API_KEY=your-tavily-api-key
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# ── AI ────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── 로컬 서버 ─────────────────────────────────────────
PORT=3000
NODE_ENV=development

# 로컬 테스트:
#   npm run dev          → Vercel dev (배포와 동일, 최초 1회: npx vercel login)
#   npm run dev:express  → Express 대안 (로그인 없이 api/*.js 동일 실행)
#
# Vercel 환경변수 동기화 (.env → Vercel):
#   npm run sync:vercel-env
#   또는  .\scripts\sync-vercel-env.cmd
