# 이 파일을 복사해 .env 로 저장한 뒤 실제 값을 입력하세요.
#   copy .env.sample .env   (Windows)
#   cp .env.sample .env     (macOS/Linux)
#
# .env 는 Git·Cursor 모두에서 제외됩니다.

# ── Supabase ──────────────────────────────────────────
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── 검색 API ──────────────────────────────────────────
TAVILY_API_KEY=your-tavily-api-key
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# ── AI ────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── 카카오톡 (나에게 보내기) ───────────────────────────
# 카카오 개발자 콘솔 → [앱] > [플랫폼 키] > [REST API 키] > Redirect URI 등록
#   (APP_BASE_URL + /api/kakao/callback 과 동일해야 함 — KOE006 방지)
KAKAO_REST_API_KEY=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret
APP_BASE_URL=https://research-silk-three.vercel.app
# 선택: 미설정 시 APP_BASE_URL/api/kakao/callback 자동 사용
# KAKAO_REDIRECT_URI=https://research-silk-three.vercel.app/api/kakao/callback

# ── 로컬 서버 ─────────────────────────────────────────
PORT=3000
NODE_ENV=development

# 로컬 테스트:
#   npm run dev          → Vercel dev (배포와 동일, 최초 1회: npx vercel login)
#   npm run dev:express  → Express 대안 (로그인 없이 api/*.js 동일 실행)
#
# Vercel 환경변수 동기화 (.env → Vercel):
#   npm run sync:vercel-env
#   또는  .\scripts\sync-vercel-env.cmd
