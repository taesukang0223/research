{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install --omit=dev || true",
  "buildCommand": null,
  "functions": {
    "api/tavily.js": { "maxDuration": 30 },
    "api/search.js": { "maxDuration": 15 },
    "api/gemini.js": { "maxDuration": 60 },
    "api/research.js": { "maxDuration": 90 },
    "api/reports.js": { "maxDuration": 15 },
    "api/analyze-file.js": { "maxDuration": 120 },
    "api/kakao/auth.js": { "maxDuration": 15 },
    "api/kakao/callback.js": { "maxDuration": 15 },
    "api/kakao/status.js": { "maxDuration": 10 },
    "api/kakao/logout.js": { "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/report", "destination": "/report.html" }
  ]
}
